			frame.ZIndex = expanded and 10 or 1
		end)

		local methods = {
			SetValue = function(_, value)
				if multiSelect then
					if type(value) == "table" then
						selected = value
					else
						selected = { value }
					end
				else
					selected = value
				end
				UpdateSelectedText()
				callback(selected)
			end,
			SetValues = function(_, values)
