				end
			end,
			GetValue = function()
				return selected
			end,
			Refresh = function(_, newOptions)
				options = newOptions
				RefreshOptions("")
			end,
		}

		if tab._library then
			tab._library:_RegisterConfigElement(flag, "Dropdown", function()
				return selected
			end, function(value)
				methods:SetValue(value)
			end)
		end

		return methods
	end

