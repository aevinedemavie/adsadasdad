		dot1.ZIndex = 100
		dot1.Parent = resizeIcon
		local dot1Corner = Instance.new("UICorner", dot1)
		dot1Corner.CornerRadius = UDim.new(1, 0)

		local dot2 = Instance.new("Frame")
		dot2.Size = UDim2.new(0, 2, 0, 2)
		dot2.Position = UDim2.new(1, -2, 0.5, -1)
		dot2.AnchorPoint = Vector2.new(1, 0.5)
		dot2.BackgroundColor3 = Color3.fromRGB(60, 60, 68)
		dot2.BorderSizePixel = 0
		dot2.ZIndex = 100
		dot2.Parent = resizeIcon
		local dot2Corner = Instance.new("UICorner", dot2)
		dot2Corner.CornerRadius = UDim.new(1, 0)

		local dot3 = Instance.new("Frame")
		dot3.Size = UDim2.new(0, 2, 0, 2)
		dot3.Position = UDim2.new(0.5, -1, 1, -2)
		dot3.AnchorPoint = Vector2.new(0.5, 1)
		dot3.BackgroundColor3 = Color3.fromRGB(60, 60, 68)
		dot3.BorderSizePixel = 0
		dot3.ZIndex = 100
		dot3.Parent = resizeIcon
		local dot3Corner = Instance.new("UICorner", dot3)
		dot3Corner.CornerRadius = UDim.new(1, 0)

		local resizing = false
		local resizeStart, startSize

		resizeHandle.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				resizing = true
				resizeStart = input.Position
				startSize = frame.Size

				for _, d in pairs({dot1, dot2, dot3}) do
					TweenService:Create(d, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(100, 100, 110) }):Play()
				end

				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						resizing = false
						for _, d in pairs({dot1, dot2, dot3}) do
							TweenService:Create(d, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(60, 60, 68) }):Play()
						end
					end
				end)
			end
		end)

		resizeHandle.MouseEnter:Connect(function()
			for _, d in pairs({dot1, dot2, dot3}) do
				TweenService:Create(d, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(90, 90, 100) }):Play()
			end
		end)

		resizeHandle.MouseLeave:Connect(function()
			if not resizing then
				for _, d in pairs({dot1, dot2, dot3}) do
					TweenService:Create(d, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(60, 60, 68) }):Play()
				end
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = input.Position - resizeStart
				local newW = math.clamp(startSize.X.Offset + delta.X, minW, maxW)
				local newH = math.clamp(startSize.Y.Offset + delta.Y, minH, maxH)
				TweenService:Create(frame, TweenInfo.new(0.05), {
					Size = UDim2.new(0, newW, 0, newH)
				}):Play()
			end
		end)
	end

