	function Library:SetAutoSave(enabled)
		self._autoSave = enabled
		if enabled then
			task.spawn(function()
				while self._autoSave and self.screenGui and self.screenGui.Parent do
					task.wait(30)
					if self._autoSave then
						local success = self:SaveConfig(self._currentConfig)
						if success then
							chx("Auto-saved config: " .. self._currentConfig, 2)
						end
					end
				end
			end)
		end
	end

	function Library:SaveConfig(configName)
		if not writefile then
			chx("Config system not supported", 3)
			return false
		end
		local folder = self:GetConfigFolder()
		local path = folder .. "/" .. configName .. ".json"
		local configData = {}
		for id, element in pairs(self._configElements) do
			local value = element.getValue()
			if typeof(value) == "Color3" then
				value = { R = value.R, G = value.G, B = value.B, _type = "Color3" }
			elseif typeof(value) == "EnumItem" then
				value = { _type = "EnumItem", _enum = tostring(value.EnumType), _value = value.Name }
			end
			configData[id] = value
		end
		local success, err = pcall(function()
			writefile(path, hs:JSONEncode(configData))
		end)
		if success then
			self._currentConfig = configName
			chx("Saved as: " .. configName, 2)
			return true
		else
			chx("Failed to save config", 3)
			return false
		end
	end

	function Library:LoadConfig(configName)
		if not readfile or not isfile then
			chx("Config system not supported", 3)
			return false
		end
		local path = self:GetConfigFolder() .. "/" .. configName .. ".json"
		if not isfile(path) then
			chx("Config not found: " .. configName, 3)
			return false
		end
		local success, data = pcall(function()
			return hs:JSONDecode(readfile(path))
		end)
		if not success or not data then
			chx("Failed to load config", 3)
			return false
		end
		for id, value in pairs(data) do
			if self._configElements[id] then
				if type(value) == "table" and value._type == "Color3" then
					value = Color3.new(value.R, value.G, value.B)
				elseif type(value) == "table" and value._type == "EnumItem" then
					value = Enum[value._enum][value._value]
				end
				pcall(function()
					self._configElements[id].setValue(value)
				end)
			end
		end
		self._currentConfig = configName
		chx("Loaded: " .. configName, 2)
		return true
	end

	function Library:DeleteConfig(configName)
		if not delfile or not isfile then
			return false
		end
		local path = self:GetConfigFolder() .. "/" .. configName .. ".json"
		if isfile(path) then
			delfile(path)
			chx("Deleted: " .. configName, 2)
			return true
		end
		return false
	end

	function Library:SetAutoLoad(enabled, defaultConfig)
		self._autoLoad = enabled
		self._defaultAutoLoadConfig = defaultConfig or "default"
		if enabled then
			if self._defaultAutoLoadConfig then
				self:LoadConfig(self._defaultAutoLoadConfig)
			end
		end
	end

	function Library:ClearAutoLoad()
		self._autoLoad = false
		self._defaultAutoLoadConfig = nil
	end

	function Library:ExportSelectedConfig(selectedDropdown)
		local selectedConfigName = selectedDropdown:GetValue()
		if not selectedConfigName or selectedConfigName == "" then
			return nil
		end
		local folder = self:GetConfigFolder()
		local path = folder .. "/" .. selectedConfigName .. ".json"
		if isfile(path) then
			return readfile(path)
		else
			return nil
		end
	end

	function Library:ImportConfigFromString(jsonText, overwrite)
		if not jsonText or jsonText == "" then
			chx("Input JSON kosong", 3)
			return false
		end

		local ok, data = pcall(function()
			return hs:JSONDecode(jsonText)
		end)
		if not ok or type(data) ~= "table" then
			chx("JSON tidak valid", 3)
			return false
		end

		for id, value in pairs(data) do
			local element = self._configElements[id]
			if element then
				if type(value) == "table" and value._type == "Color3" then
					value = Color3.new(value.R, value.G, value.B)
				elseif type(value) == "table" and value._type == "EnumItem" then
					value = Enum[value._enum][value._value]
				end
				pcall(function()
					element.setValue(value)
				end)
			end
		end

		chx("Config berhasil di-import", 2)
		return true
	end

	function Library:ResetConfig()
		for id, element in pairs(self._configElements) do
			if element.type == "Slider" then
				element.setValue(0)
			elseif element.type == "Toggle" then
				element.setValue(false)
			elseif element.type == "Dropdown" then
				element.setValue(nil)
			elseif element.type == "Keybind" then
				element.setValue(Enum.KeyCode.Unknown)
			elseif element.type == "ColorPicker" then
				element.setValue(Color3.fromRGB(255, 255, 255))
			elseif element.type == "Input" then
				element.setValue("")
			end
		end
		chx("Config reset to default", 2)
	end

